generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id                  String            @id @default(cuid(2))
  name                String
  slug                String            @unique
  logo_url            String?
  inviteCode          String?           @unique @default(cuid(2))
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  conference          String
  matchHistoryConsent Boolean           @default(false)
  division            Int?
  tag                 String?
  calendarToken       String?           @unique @default(cuid(2))
  compositions        Composition[]
  events              Event[]
  matches             Match[]
  messages            Message[]
  players             Player[]
  joinRequests        TeamJoinRequest[]
  users               User[]
}

model User {
  id            String            @id @default(cuid(2))
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String            @default("member")
  playerId      String?           @unique
  teamId        String?
  calendarToken String?           @unique @default(cuid(2))
  dataConsent   Boolean           @default(false)
  accounts      Account[]
  sessions      Session[]
  joinRequests  TeamJoinRequest[]
  player        Player?           @relation(fields: [playerId], references: [id])
  team          Team?             @relation(fields: [teamId], references: [id])
}

model Account {
  id                String  @id @default(cuid(2))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid(2))
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Player {
  id           String             @id @default(cuid(2))
  teamId       String?
  puuid        String?            @unique
  name         String
  riot_name    String?
  riot_tag     String?
  role         String             @default("flex")
  avatar_color String             @default("#FF4655")
  created_at   DateTime           @default(now())
  availability Availability[]
  stats        MatchPlayerStats[]
  messages     Message[]
  team         Team?              @relation(fields: [teamId], references: [id])
  user         User?
}

model Map {
  id                  String        @id
  name                String
  displayIcon         String?
  splash              String?
  listViewIcon        String?
  listViewIconTall    String?
  premierBackground   String?
  mapUrl              String?
  tacticalDescription String?
  compositions        Composition[]
  events              Event[]
}

model Composition {
  id          Int        @id @default(autoincrement())
  teamId      String?
  map_id      String
  name        String
  description String?
  agent_1     String
  agent_2     String
  agent_3     String
  agent_4     String
  agent_5     String
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  map         Map        @relation(fields: [map_id], references: [id])
  team        Team?      @relation(fields: [teamId], references: [id])
  strategies  Strategy[]
}

model Strategy {
  id             Int         @id @default(autoincrement())
  composition_id Int
  name           String
  side           String      @default("attack")
  description    String?
  canvas_data    Json?       @default("{}")
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  composition    Composition @relation(fields: [composition_id], references: [id], onDelete: Cascade)
}

model Season {
  id         String    @id
  name       String    @default("Temporada")
  starts_at  DateTime?
  ends_at    DateTime?
  created_at DateTime  @default(now())
  events     Event[]
  matches    Match[]
}

model Event {
  id                Int            @id @default(autoincrement())
  teamId            String?
  title             String?
  type              String         @default("match")
  date              String
  time              String
  end_date          String?
  end_time          String?
  description       String?
  map               String?
  premier_week      String?
  premier_season_id String?
  match_id          String?
  status            String         @default("scheduled")
  created_at        DateTime       @default(now())
  availability      Availability[]
  map_obj           Map?           @relation(fields: [map], references: [id])
  match             Match?         @relation(fields: [match_id], references: [riot_match_id])
  season            Season?        @relation(fields: [premier_season_id], references: [id])
  team              Team?          @relation(fields: [teamId], references: [id])

  @@unique([teamId, date, time, type], name: "teamId_date_time_type")
}

model Availability {
  id         Int      @id @default(autoincrement())
  event_id   Int
  player_id  String
  status     String   @default("pending")
  note       String?
  updated_at DateTime @default(now())
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  player     Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([event_id, player_id])
}

model Message {
  id         Int      @id @default(autoincrement())
  teamId     String?
  channel    String   @default("general")
  player_id  String
  content    String
  created_at DateTime @default(now())
  player     Player   @relation(fields: [player_id], references: [id])
  team       Team?    @relation(fields: [teamId], references: [id])
}

model Match {
  id                Int                @id @default(autoincrement())
  teamId            String?
  riot_match_id     String             @unique
  map_id            String
  map_name          String
  game_mode         String
  game_start        DateTime
  game_length_ms    Int
  is_ranked         Boolean            @default(false)
  queue_id          String?
  season_id         String?
  premier_season_id String?
  team_blue_score   Int                @default(0)
  team_red_score    Int                @default(0)
  team_blue_won     Boolean            @default(false)
  event_id          Int?
  raw_data          Json?
  events            Event[]
  season            Season?            @relation(fields: [premier_season_id], references: [id])
  team              Team?              @relation(fields: [teamId], references: [id])
  player_stats      MatchPlayerStats[]
}

model MatchPlayerStats {
  id               Int     @id @default(autoincrement())
  match_id         Int
  puuid            String
  player_id        String?
  character_id     String
  team_id          String
  kills            Int     @default(0)
  deaths           Int     @default(0)
  assists          Int     @default(0)
  score            Int     @default(0)
  rounds_played    Int     @default(0)
  competitive_tier Int?
  ability_casts    Json?
  match            Match   @relation(fields: [match_id], references: [id])
  player           Player? @relation(fields: [player_id], references: [id])

  @@unique([match_id, puuid])
}

model TeamJoinRequest {
  id         String   @id @default(cuid(2))
  userId     String
  teamId     String
  status     String   @default("pending")
  created_at DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}
